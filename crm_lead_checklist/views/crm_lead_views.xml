<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_crm_lead_form_checklist" model="ir.ui.view">
        <field name="name">crm.lead.form.checklist</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Checklist">
                    <group>
                        <field name="checklist_progress" widget="progressbar" readonly="1"/>
                    </group>
                    <field name="checklist_line_ids" nolabel="1">
                        <list delete="0" create="0" editable="bottom">
                            <field name="name" readonly="1"/>
                            <field name="is_done"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
    <record id="crm_lead_kanban_checklist_progress" model="ir.ui.view">
        <field name="name">crm.lead.kanban.checklist.progress</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_kanban_view_leads"/>
        <field name="arch" type="xml">
            <xpath expr="//footer/div[field[@name='priority'] and field[@name='activity_ids']]" position="after">
                <div class="mt-2">
                    <field name="checklist_progress" widget="progressbar"/>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
