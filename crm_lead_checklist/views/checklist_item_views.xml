<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_crm_lead_checklist_item_tree" model="ir.ui.view">
        <field name="name">crm.lead.checklist.item.list</field>
        <field name="model">crm.lead.checklist.item</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence"/>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    <record id="action_crm_lead_checklist_item" model="ir.actions.act_window">
        <field name="name">Checklist Items</field>
        <field name="res_model">crm.lead.checklist.item</field>
        <field name="view_mode">list</field>
    </record>
    <menuitem
            id="menu_crm_lead_checklist_item"
            name="Checklist Items"
            parent="crm.crm_menu_sales"
            action="action_crm_lead_checklist_item"
            sequence="6"
    />
</odoo>